# App
FLASK_SECRET_KEY=replace-with-a-strong-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Database
# sqlite or mysql
DB_BACKEND=mysql

# SQLite (used when DB_BACKEND=sqlite)
# For local dev: ./quiz.db
# Vercel default also reads ./quiz.db (package filesystem, read-only)
DB_PATH=./quiz.db

# MySQL (used when DB_BACKEND=mysql)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=quiz
MYSQL_USER=quiz_user
MYSQL_PASSWORD=change-me

# MySQL connection reuse
MYSQL_POOL_ENABLED=true
MYSQL_POOL_MAX_IDLE_SECONDS=45

# Collector / push
COLLECTOR_PUSH=true
COLLECTOR_PUSH_TOKEN=

# AI settings file path (optional)
AI_SETTINGS_PATH=./ai_settings.json

# Redis cache (optional)
# If you do not use Redis, set REDIS_ENABLED=false
REDIS_ENABLED=false

# Preferred if available
REDIS_URL=

# Fallback Redis connection fields
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache tuning
REDIS_CACHE_PREFIX=quiz
REDIS_PUBLIC_LIB_CACHE_TTL=600
