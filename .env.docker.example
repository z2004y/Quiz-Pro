# App
FLASK_SECRET_KEY=replace-with-a-strong-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# MySQL
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_DATABASE=quiz
MYSQL_USER=quiz_user
MYSQL_PASSWORD=change-db-password

# Optional app tuning
MYSQL_POOL_ENABLED=true
MYSQL_POOL_MAX_IDLE_SECONDS=45

# Redis
REDIS_ENABLED=true
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_PREFIX=quiz
REDIS_PUBLIC_LIB_CACHE_TTL=600

# Collector
COLLECTOR_PUSH=true
COLLECTOR_PUSH_TOKEN=
